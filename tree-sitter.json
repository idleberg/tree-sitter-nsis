{
  "grammars": [
    {
      "name": "nsis",
      "camelcase": "NSIS",
      "scope": "source.nsis",
      "path": ".",
      "file-types": [
        "nsi",
        "nsh"
      ],
      "highlights": "queries/highlights.scm",
      "folds": "queries/folds.scm",
      "indents": "queries/indents.scm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "NSIS grammar for tree-sitter",
    "authors": [
      {
        "name": "Jan T. Sott"
      }
    ],
    "links": {
      "repository": "https://github.com/idleberg/tree-sitter-nsis"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
